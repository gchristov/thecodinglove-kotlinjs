FROM node:22-slim AS npm

ARG PORT
ARG API_URL
ARG SLACK_REQUEST_VERIFICATION
ARG SLACK_SLASH_COMMAND_RECEIVED_PUBSUB_TOPIC
ARG SLACK_INTERACTIVITY_RECEIVED_PUBSUB_TOPIC
ARG SLACK_SELF_DESTRUCT_MESSAGE_PUBSUB_TOPIC
# Args get wiped on multistage builds so we persist them in the environment
ENV PORT=${PORT}
ENV API_URL=${API_URL}
ENV SLACK_REQUEST_VERIFICATION=${SLACK_REQUEST_VERIFICATION}
ENV SLACK_SLASH_COMMAND_RECEIVED_PUBSUB_TOPIC=${SLACK_SLASH_COMMAND_RECEIVED_PUBSUB_TOPIC}
ENV SLACK_INTERACTIVITY_RECEIVED_PUBSUB_TOPIC=${SLACK_INTERACTIVITY_RECEIVED_PUBSUB_TOPIC}
ENV SLACK_SELF_DESTRUCT_MESSAGE_PUBSUB_TOPIC=${SLACK_SELF_DESTRUCT_MESSAGE_PUBSUB_TOPIC}

WORKDIR /app

# Step 1: Install Node.js dependencies
COPY /productionExecutable/package.json .
RUN npm install --only=production

# Step 2: Copy app files
COPY /productionExecutable .

# Step 3: Run binaries
FROM npm AS run
WORKDIR /app
CMD exec node --enable-source-maps slack-service.js -port ${PORT} -apiUrl ${API_URL} -slackRequestVerification ${SLACK_REQUEST_VERIFICATION} -slackSlashCommandReceivedPubSubTopic ${SLACK_SLASH_COMMAND_RECEIVED_PUBSUB_TOPIC} -slackInteractivityReceivedPubSubTopic ${SLACK_INTERACTIVITY_RECEIVED_PUBSUB_TOPIC} -slackSelfDestructMessagePubSubTopic ${SLACK_SELF_DESTRUCT_MESSAGE_PUBSUB_TOPIC}
